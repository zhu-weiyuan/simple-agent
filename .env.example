# OpenAI 兼容 API 配置（本地模型）
OPENAI_API_KEY=your_key_here
OPENAI_BASE_URL=http://localhost:8080
OPENAI_MODEL=Qwen/Qwen2.5-72B-Instruct

# MCP 天气服务器配置（可选）
# 设置此项后，agent 会自动启动 MCP 服务器并集成其工具
# 示例（Python 运行本地服务器）:
# MCP_WEATHER_COMMAND=python weather_mcp_server.py
# 示例（使用 npx 运行社区服务器，如果存在）:
# MCP_WEATHER_COMMAND=npx -y @modelcontextprotocol/server-weather --api-key=xxx
MCP_WEATHER_COMMAND=
